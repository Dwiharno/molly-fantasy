APP_NAME="Molly Fantasy"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=molly_fantasy
DB_USERNAME=root
DB_PASSWORD=

# PostgreSQL hosted (Neon/Render):
# DB_CONNECTION=pgsql
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@mollyfantasy.co.id"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================================
# GOOGLE SHEETS INTEGRATION
# ==========================================================
# 1. Buat project di https://console.cloud.google.com
# 2. Aktifkan Google Sheets API
# 3. Buat Service Account, download JSON credential
# 4. Simpan file JSON di storage/app/google/service-account.json
# 5. Share Spreadsheet ke email service account (sebagai Editor)
GOOGLE_SHEETS_CREDENTIALS_PATH=storage/app/google/service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_MASTER_ITEM="Master Item"
GOOGLE_SHEETS_SHEET_REDEEM="Redeem"
GOOGLE_SHEETS_SHEET_STOCK_OPNAME="Stock Opname"
GOOGLE_SHEETS_SHEET_USER="User"
GOOGLE_SHEETS_SHEET_LOG="Log"
GOOGLE_SHEETS_SYNC_ENABLED=true

# ==========================================================
# THERMAL PRINTER (58mm) - dicetak via browser window.print()
# menggunakan CSS khusus resources/css/thermal.css
# ==========================================================
THERMAL_PRINTER_WIDTH_MM=58

# ==========================================================
# APLIKASI
# ==========================================================
STOCK_MINIMUM_NOTIFICATION=true
BARCODE_TICKET_LENGTH=16
BARCODE_TICKET_DIGIT_START=10
BARCODE_TICKET_DIGIT_LENGTH=5

# Akun awal saat `php artisan db:seed --force` dijalankan di server.
ADMIN_EMAIL=superadmin@mollyfantasy.co.id
ADMIN_PASSWORD=ChangeMe123!

# Kredensial Google Service Account dapat disimpan sebagai base64 di hosting.
GOOGLE_SHEETS_CREDENTIALS_BASE64=
